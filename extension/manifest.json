{
  "manifest_version": 3,
  "name": "JobTiered",
  "version": "5.0",
  "description": "AI-powered job grading directly on your favorite job search platforms.",
  "permissions": [
    "storage",
    "alarms",
    "downloads",
    "activeTab"
  ],
  "host_permissions": [
    "https://openrouter.ai/api/*",
    "https://*.supabase.co/*",
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://*.glassdoor.com/*",
    "*://*.ziprecruiter.com/*",
    "*://*.governmentjobs.com/*",
    "*://*.usajobs.gov/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/favicon-16x16.png",
      "32": "images/favicon-32x32.png",
      "128": "images/android-chrome-192x192.png",
      "192": "images/android-chrome-192x192.png",
      "512": "images/android-chrome-512x512.png"
    }
  },
  "icons": {
    "16": "images/favicon-16x16.png",
    "32": "images/favicon-32x32.png",
    "128": "images/android-chrome-192x192.png",
    "192": "images/android-chrome-192x192.png",
    "512": "images/android-chrome-512x512.png"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.linkedin.com/my-items/saved-jobs/*",
        "*://*.linkedin.com/feed/*",
        "*://*.indeed.com/*",
        "*://*.glassdoor.com/Job/*",
        "*://*.glassdoor.com/job-listing/*",
        "*://*.glassdoor.com/Search/*",
        "*://*.glassdoor.com/Jobs/*",
        "*://*.glassdoor.com/partner/*",
        "*://*.ziprecruiter.com/*",
        "*://*.governmentjobs.com/*",
        "*://*.usajobs.gov/*"
      ],
      "js": [
        "content/constants.js",
        "content/utils.js",
        "content/ui.js",
        "content/cache.js",
        "content/keywords.js",
        "content/platforms/linkedin.js",
        "content/platforms/indeed.js",
        "content/platforms/glassdoor.js",
        "content/platforms/ziprecruiter.js",
        "content/platforms/usajobs.js",
        "content/platforms/governmentjobs.js",
        "content/grading.js",
        "content/queue.js",
        "content/scanner.js",
        "content/main.js"
      ],
      "run_at": "document_idle"
    }
  ]
}